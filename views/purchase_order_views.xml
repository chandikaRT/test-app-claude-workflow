<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extend Purchase Order Form View - Add Smart Button -->
    <record id="view_purchase_order_form_inherit" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.test_app</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_material_requests" type="object" class="oe_stat_button" icon="fa-list-alt"
                        invisible="material_request_count == 0">
                    <field name="material_request_count" widget="statinfo" string="Material Requests"/>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
