<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Material Request Sequence -->
        <record id="seq_material_request" model="ir.sequence">
            <field name="name">Material Request</field>
            <field name="code">test_app.material.request</field>
            <field name="prefix">MR/</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="implementation">standard</field>
            <field name="use_date_range" eval="False"/>
        </record>

        <!-- Purchase Request Sequence -->
        <record id="seq_purchase_request" model="ir.sequence">
            <field name="name">Purchase Request</field>
            <field name="code">test_app.purchase.request</field>
            <field name="prefix">PR/</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="implementation">standard</field>
            <field name="use_date_range" eval="False"/>
        </record>

    </data>
</odoo>
