<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Purchase Request Convert Wizard Form -->
    <record id="view_purchase_request_convert_wizard_form" model="ir.ui.view">
        <field name="name">test_app.purchase.request.convert.wizard.form</field>
        <field name="model">test_app.purchase.request.convert.wizard</field>
        <field name="arch" type="xml">
            <form string="Convert to Purchase Order">
                <group>
                    <field name="purchase_request_id" invisible="1"/>
                    <field name="vendor_id" options="{'no_create': True, 'no_open': True}"/>
                </group>
                <p class="text-muted">
                    Please select a vendor to convert this purchase request into a purchase order.
                </p>
                <footer>
                    <button string="Convert to Purchase Order" name="action_convert" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Wizard Action -->
    <record id="action_purchase_request_convert_wizard" model="ir.actions.act_window">
        <field name="name">Select Vendor</field>
        <field name="res_model">test_app.purchase.request.convert.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_purchase_request_id': active_id}</field>
    </record>

</odoo>
